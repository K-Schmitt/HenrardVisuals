# =========================================
# HenrardVisuals - Git Ignore
# =========================================

# ----------------------------------------
# Dependencies
# ----------------------------------------
node_modules/
.pnpm-store/

# ----------------------------------------
# Build Output
# ----------------------------------------
dist/
build/
.vite/

# ----------------------------------------
# Environment & Secrets
# ----------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# ----------------------------------------
# IDE & Editor
# ----------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ----------------------------------------
# OS Files
# ----------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------------------
# Test & Coverage
# ----------------------------------------
coverage/
*.lcov
.nyc_output/

# ----------------------------------------
# Logs
# ----------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----------------------------------------
# Docker Volumes (Data - NOT config)
# ----------------------------------------
volumes/db/data/
volumes/storage/stub/

# ----------------------------------------
# Uploaded Files (User Data)
# ----------------------------------------
uploads/

# ----------------------------------------
# TypeScript
# ----------------------------------------
*.tsbuildinfo

# ----------------------------------------
# Claude AI
# ----------------------------------------
.claude/

# ----------------------------------------
# Misc
# ----------------------------------------
*.local
.cache/
*.har
*.zip
*.tar.gz

# ----------------------------------------
# Temporary & Backup Files
# ----------------------------------------
*.tmp
*.temp
*.bak
*.backup
*~

# ----------------------------------------
# Internal / Debug Docs (not for public repo)
# ----------------------------------------
docs/AUDIT.md
docs/DEBUG_UPLOAD.md

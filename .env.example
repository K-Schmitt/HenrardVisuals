# =========================================
# HenrardVisuals - Environment Variables
# =========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
#
# Generate keys with:
#   node generate-keys.cjs
# or:
#   openssl rand -base64 48

# ----------------------------------------
# PostgreSQL Database
# ----------------------------------------
POSTGRES_PASSWORD=

# ----------------------------------------
# JWT Configuration
# ----------------------------------------
# Must be at least 32 characters
# Generate: openssl rand -base64 48
JWT_SECRET=

# JWT Token Expiry (seconds)
JWT_EXPIRY=3600

# ----------------------------------------
# Supabase Keys
# ----------------------------------------
# Generate with: node generate-keys.cjs
# These are derived from JWT_SECRET and must match
ANON_KEY=
SERVICE_ROLE_KEY=

# ----------------------------------------
# URLs
# ----------------------------------------
SITE_URL=http://localhost:5173
API_EXTERNAL_URL=http://localhost:8000

# ----------------------------------------
# Vite (Frontend)
# ----------------------------------------
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=

# ----------------------------------------
# Authentication Settings
# ----------------------------------------
# Set to "true" in production to prevent unauthorized signups
DISABLE_SIGNUP=true
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

# Additional redirect URLs (comma-separated)
ADDITIONAL_REDIRECT_URLS=

# ----------------------------------------
# SMTP Configuration (Optional)
# ----------------------------------------
# Required for email confirmations in production
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=
SMTP_SENDER_NAME=HenrardVisuals

# ----------------------------------------
# Email URL Paths
# ----------------------------------------
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
